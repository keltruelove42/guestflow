{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["PRISMA_*", "DATABASE_URL", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "generate": {
      "cache": false
    }
  }
}
