// packages/db/prisma/schema.prisma — verbatim from docs/03-data-model.md
generator client {
  // Engine type: default (library) on Vercel — its bundler has first-class
  // support for tracing the native engine. Local/sandbox dev sets
  // PRISMA_CLIENT_ENGINE_TYPE=client at generate time to use the WASM engine
  // (no native binary downloads needed).
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- tenancy & auth ----------
model Org {
  id                 String        @id @default(cuid())
  name               String
  mode               OrgMode       @default(DEMO)
  vertical           Vertical      @default(RENTALS)
  timezone           String        @default("America/New_York")
  quietStart         Int           @default(21)
  quietEnd           Int           @default(9)
  abandonmentMinutes Int           @default(60)
  variables          Json? // org-level merge variables: { host_name, business_name, booking_link, custom... }
  plan               String        @default("TRIAL") // TRIAL | STARTER | GROWTH | ENTERPRISE
  /// End of the 7-day free trial. Null = no expiry (legacy orgs / paid).
  trialEndsAt        DateTime?
  /// AI reply/booking agent mode: OFF | SUGGEST | AUTOPILOT.
  aiAgentMode        String        @default("OFF")
  /// Lead enrichment: auto-enrich new leads, and an optional outbound webhook
  /// URL (e.g. a Clay table's webhook source) to run an external provider.
  enrichAuto         Boolean       @default(false)
  enrichWebhookUrl   String?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  bookingSlug        String?       @unique
  bookingSettings    Json? // { enabled, slotMinutes, bufferMinutes, startHour, endHour, days: [1..5] }
  appointments       Appointment[]
  invitations        Invitation[]
  demoClearedAt      DateTime? // set when user clears seed/demo rows
  brandSettings      BrandSettings?
  users              User[]
  properties         Property[]
  leads              Lead[]
  campaigns          Campaign[]
  sequences          Sequence[]
  integrations       Integration[]
  generatedImages    GeneratedImage[]
  savedReports       SavedReport[]
  apiKeys            ApiKey[]
  createdAt          DateTime      @default(now())
}

/// Org API key for the MCP server / programmatic access. Only the SHA-256
/// hash is stored; the raw key (lc_live_…) is shown once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  orgId      String
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  label      String
  hash       String    @unique
  /// Last 4 chars of the raw key, for display ("…a1b2").
  last4      String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())

  @@index([orgId])
  @@index([hash])
}

/// A pending / resolved AI-drafted reply for a lead (Suggest mode), or a
/// record of an autopilot send. The lead detail surfaces PENDING ones for the
/// owner to edit/send/dismiss.
model AiSuggestion {
  id         String   @id @default(cuid())
  orgId      String
  leadId     String
  channel    String // EMAIL | SMS
  draft      String   @db.Text
  /// One-line reason/summary the agent gives (e.g. what it understood/booked).
  rationale  String?
  /// PENDING | SENT | DISMISSED | AUTOSENT
  status     String   @default("PENDING")
  /// True when the agent booked (or proposed) an appointment in this turn.
  bookedAppointmentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId, status])
  @@index([leadId, status])
}

/// A saved custom report (Growth/Enterprise). `spec` is the report-builder
/// definition (metric, groupBy, granularity, dateRange, filters, chart type).
model SavedReport {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  spec      Json
  /// Display order on the reports dashboard.
  position  Int      @default(0)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, position])
}

/// AI-generated hero images (Growth/Enterprise). Every generation is recorded
/// so an asset-library gallery can be added later with no migration.
model GeneratedImage {
  id         String    @id @default(cuid())
  orgId      String
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// The sequence ("template") this was generated for; kept on sequence delete.
  sequenceId String?
  prompt     String    @db.Text
  imageUrl   String
  createdAt  DateTime  @default(now())

  @@index([orgId, createdAt])
}

enum OrgMode {
  DEMO
  LIVE
}

/// Brand source of truth — one row per org. Every branded surface (email
/// header/footer, previews, future image gen) reads from here; nothing
/// duplicates brand config.
model BrandSettings {
  id           String   @id @default(cuid())
  orgId        String   @unique
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  logoUrl      String? // uploaded once to Vercel Blob
  primaryColor String   @default("#1a1a2e")
  accentColor  String   @default("#4f46e5")
  businessName String?
  font         String? // optional font-family preference for email rendering
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

/// Industry vertical — selects terminology, templates, and demo data
enum Vertical {
  RENTALS
  TRADES
  BEAUTY
  DEALERSHIPS
  SAAS
  ECOMMERCE
  REALESTATE
  HOTELS
}

model User {
  id                 String    @id
  orgId              String
  org                Org       @relation(fields: [orgId], references: [id])
  email              String    @unique
  name               String?
  role               Role      @default(OWNER)
  passwordHash       String?
  expoPushTokens     String[]
  // Email verification (gates live sending for new trial accounts).
  emailVerifiedAt    DateTime?
  emailVerifyHash    String? // sha256 of the emailed token
  emailVerifyExpires DateTime?
  createdAt          DateTime  @default(now())

  @@index([emailVerifyHash])
}

model Invitation {
  id         String    @id @default(cuid())
  orgId      String
  org        Org       @relation(fields: [orgId], references: [id])
  email      String
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([orgId])
}

enum Role {
  OWNER
  MEMBER
}

// ---------- properties ----------
model Property {
  id               String              @id @default(cuid())
  orgId            String
  org              Org                 @relation(fields: [orgId], references: [id])
  name             String
  location         String?
  bedrooms         Int?
  type             PropertyType        @default(SHORT_TERM)
  photoUrl         String?
  imageUrl         String? // listing thumbnail pulled from the booking URL
  description      String? @db.Text // short blurb pulled from the listing
  directBookingUrl String?
  knowledgeBase    String?             @db.Text
  archived         Boolean             @default(false)
  isDemo           Boolean             @default(false) // seed/demo — clearable without touching real rows
  leads            Lead[]
  campaigns        Campaign[]
  availability     AvailabilityBlock[]
  createdAt        DateTime            @default(now())

  @@index([orgId, archived])
  @@index([orgId, isDemo])
}

enum PropertyType {
  SHORT_TERM
  LONG_TERM
  BOTH
}

/// Manual / synced date blocks — calendar shows these as unavailable
model AvailabilityBlock {
  id         String           @id @default(cuid())
  orgId      String
  propertyId String
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  startDate  DateTime         @db.Date
  endDate    DateTime         @db.Date // inclusive end (checkout night stays available)
  kind       AvailabilityKind @default(BLOCKED)
  note       String?
  isDemo     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([propertyId, startDate, endDate])
  @@index([orgId])
}

enum AvailabilityKind {
  BOOKED
  BLOCKED
  HOLD
}

// ---------- leads (CRM core) ----------
model Lead {
  id             String     @id @default(cuid())
  orgId          String
  org            Org        @relation(fields: [orgId], references: [id])
  propertyId     String?
  property       Property?  @relation(fields: [propertyId], references: [id])
  name           String
  email          String?
  phone          String?
  address        String?
  travelDates    String?
  partySize      String?
  source         LeadSource
  campaignId     String?
  campaign       Campaign?  @relation(fields: [campaignId], references: [id])
  externalRef    String?
  stage          Stage      @default(NEW)
  tags           String[]   @default([])
  ownerId        String?
  dealValueCents Int?
  followUpAt     DateTime?
  emailConsent   Boolean    @default(false)
  smsConsent     Boolean    @default(false)
  emailConsentAt DateTime?
  smsConsentAt   DateTime?
  unsubscribedAt DateTime?
  smsStoppedAt   DateTime?
  needsAttention Boolean    @default(false)
  isDemo         Boolean    @default(false)
  /// Enrichment data (company, title, industry, socials, summary, provider…).
  /// Filled by built-in AI enrichment and/or an external provider webhook (Clay).
  enrichment     Json?
  enrichedAt     DateTime?
  events         LeadEvent[]
  notes          Note[]
  enrollments    Enrollment[]
  bookings       Booking[]
  appointments   Appointment[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([orgId, externalRef])
  @@index([orgId, stage])
  @@index([orgId, source])
  @@index([orgId, propertyId])
  @@index([orgId, email])
  @@index([orgId, phone])
  @@index([orgId, isDemo])
}

enum LeadSource {
  META
  TIKTOK
  PINTEREST
  DIRECT_SITE
  WIFI
  MANUAL
  IMPORT
}

enum Stage {
  NEW
  CONTACTED
  ENGAGED
  QUOTED
  BOOKED
  LOST
}

model LeadEvent {
  id         String        @id @default(cuid())
  orgId      String
  leadId     String
  lead       Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       LeadEventType
  channel    Channel?
  title      String
  body       String?       @db.Text
  meta       Json?
  occurredAt DateTime      @default(now())

  @@index([leadId, occurredAt])
  @@index([orgId, occurredAt])
}

enum LeadEventType {
  CAPTURED
  INQUIRY_STARTED
  INQUIRY_ABANDONED
  EMAIL_SENT
  SMS_SENT
  EMAIL_SCHEDULED_SKIPPED
  REPLIED
  AI_REPLY_SENT
  MANUAL_MESSAGE
  QUOTE_SENT
  BOOKED
  LOST_MARKED
  STAGE_CHANGED
  ENROLLED
  SEQUENCE_PAUSED
  SEQUENCE_STOPPED
  SEQUENCE_COMPLETED
  NOTE_ADDED
  IMPORTED
  OPTED_OUT
  APPOINTMENT_BOOKED
  CALL_DUE
  EMAIL_OPENED
  CODE_REDEEMED
}

enum Channel {
  EMAIL
  SMS
  CALL
}

model Note {
  id        String   @id @default(cuid())
  orgId     String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  text      String   @db.Text
  createdAt DateTime @default(now())
}

// ---------- campaigns & lead forms ----------
model Campaign {
  id                   String         @id @default(cuid())
  orgId                String
  org                  Org            @relation(fields: [orgId], references: [id])
  propertyId           String?
  property             Property?      @relation(fields: [propertyId], references: [id])
  platform             AdPlatform
  name                 String
  status               CampaignStatus @default(DRAFT)
  objective            String         @default("Lead generation")
  dailyBudgetCents     Int
  audience             Json
  leadForm             Json
  autoEnrollSequenceId String?
  externalCampaignId   String?
  spendCents           Int            @default(0)
  impressions          Int            @default(0)
  clicks               Int            @default(0)
  leadsCount           Int            @default(0)
  startedAt            DateTime?
  isDemo               Boolean        @default(false)
  leads                Lead[]
  createdAt            DateTime       @default(now())

  @@index([orgId, status])
  @@index([orgId, isDemo])
}

enum AdPlatform {
  META
  TIKTOK
  PINTEREST
}

enum CampaignStatus {
  DRAFT
  IN_REVIEW
  ACTIVE
  PAUSED
  ENDED
}

// ---------- sequences & automation ----------
model Sequence {
  id          String           @id @default(cuid())
  orgId       String
  org         Org              @relation(fields: [orgId], references: [id])
  name        String
  trigger     SequenceTrigger
  active      Boolean          @default(true)
  isDemo      Boolean          @default(false)
  /// Optional hero photo (Vercel Blob URL) rendered under the branded email
  /// header for this sequence's email steps; empty = header renders alone.
  heroPhotoUrl String?
  steps       SequenceStep[]
  enrollments Enrollment[]
  createdAt   DateTime         @default(now())

  @@index([orgId, isDemo])
}

enum SequenceTrigger {
  AD_LEAD_CAPTURED
  INQUIRY_ABANDONED
  QUOTE_UNACCEPTED_48H
  CHECKOUT_PLUS_90D
  MANUAL_ONLY
}

model SequenceStep {
  id           String    @id @default(cuid())
  sequenceId   String
  sequence     Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order        Int
  delayMinutes Int
  channel      Channel
  subject      String?
  body         String    @db.Text

  @@unique([sequenceId, order])
}

model Enrollment {
  id           String             @id @default(cuid())
  orgId        String
  leadId       String
  lead         Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId   String
  sequence     Sequence           @relation(fields: [sequenceId], references: [id])
  status       EnrollmentStatus   @default(ACTIVE)
  currentStep  Int                @default(0)
  pausedReason String?
  scheduled    ScheduledMessage[]
  createdAt    DateTime           @default(now())
  completedAt  DateTime?

  @@unique([leadId, sequenceId, createdAt])
  @@index([leadId, status])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  STOPPED
  COMPLETED
}

model ScheduledMessage {
  id             String          @id @default(cuid())
  orgId          String
  enrollmentId   String
  enrollment     Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId         String
  channel        Channel
  sendAt         DateTime
  status         ScheduledStatus @default(PENDING)
  idempotencyKey String          @unique
  attempts       Int             @default(0)
  lastError      String?
  sentAt         DateTime?

  @@index([status, sendAt])
}

enum ScheduledStatus {
  PENDING
  SENT
  SKIPPED
  CANCELED
  FAILED
}

// ---------- appointments (booking calendar) ----------

model Appointment {
  id             String            @id @default(cuid())
  orgId          String
  org            Org               @relation(fields: [orgId], references: [id])
  leadId         String?
  lead           Lead?             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  typeKey        String
  title          String
  startAt        DateTime
  endAt          DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  source         String            @default("manual") // manual | public
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())

  @@index([orgId, startAt])
  @@index([orgId, status])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ---------- bookings & attribution ----------
model Booking {
  id                   String    @id @default(cuid())
  orgId                String
  leadId               String
  lead                 Lead      @relation(fields: [leadId], references: [id])
  propertyId           String?
  amountCents          Int?
  bookedAt             DateTime  @default(now())
  checkoutAt           DateTime?
  attributedCampaignId String?
  attributedSequenceId String?
  externalRef          String?

  @@index([orgId, bookedAt])
}

// ---------- integrations ----------
model Integration {
  id          String             @id @default(cuid())
  orgId       String
  org         Org                @relation(fields: [orgId], references: [id])
  provider    String
  status      IntegrationStatus  @default(DISCONNECTED)
  credentials Json?
  config      Json?
  lastSyncAt  DateTime?
  lastError   String?
  isDemo      Boolean            @default(false)

  @@unique([orgId, provider])
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}
