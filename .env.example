DATABASE_URL="postgresql://guestflow:guestflow@localhost:5432/guestflow?schema=public"

# Optional: set to "client" before `pnpm db:generate` to use Prisma's WASM engine
# (no native engine downloads — useful in sandboxes/offline). Leave unset on Vercel.
# PRISMA_CLIENT_ENGINE_TYPE=client

# Optional — leave blank to use demo auth (email + "demo" password)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo mode defaults
APP_URL="http://localhost:3000"
CRON_SECRET="dev-cron-secret"
CREDENTIALS_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Live integrations (optional until M6)
# SEND_MODE=live forces Resend/Twilio even when org is DEMO (needs keys below)
# SEND_MODE=log forces logging mocks even when org is LIVE
SEND_MODE=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
EMAIL_FROM="Taylor <stay@yourdomain.com>"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OAuth apps — required to Connect Meta / TikTok / Pinterest / Stripe from Integrations
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
STRIPE_CLIENT_ID=
STRIPE_SECRET_KEY=

# Optional platform fallbacks (prefer Integrations UI credentials)
HOSTFULLY_API_KEY=
