{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && corepack enable && pnpm install --filter @guestflow/web...",
  "buildCommand": "cd ../.. && bash scripts/vercel-build.sh",
  "ignoreCommand": "npx turbo-ignore --fallback=HEAD^1",
  "crons": [
    {
      "path": "/api/jobs/tick",
      "schedule": "0 11 * * *"
    }
  ]
}
